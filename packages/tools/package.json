{
  "name": "@emerge/tools",
  "version": "0.1.0",
  "description": "Tool registry, filesystem and bash tools, and tool composition utilities for the emerge agent harness.",
  "license": "MIT",
  "author": "emerge contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LemonCANDY42/emerge.git",
    "directory": "packages/tools"
  },
  "homepage": "https://github.com/LemonCANDY42/emerge#readme",
  "bugs": "https://github.com/LemonCANDY42/emerge/issues",
  "keywords": ["agent", "tools", "llm", "emerge", "typescript"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@emerge/kernel": "workspace:^0.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
