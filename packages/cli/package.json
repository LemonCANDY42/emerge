{
  "name": "@emerge/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "emerge": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@emerge/kernel": "workspace:*",
    "@emerge/provider-mock": "workspace:*",
    "@emerge/replay": "workspace:*",
    "@emerge/telemetry-jsonl": "workspace:*",
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
