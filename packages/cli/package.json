{
  "name": "@lwrf42/emerge-cli",
  "version": "0.1.0",
  "description": "Command-line interface for the emerge agent harness: run, replay, probe, and status commands.",
  "license": "MIT",
  "author": "emerge contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LemonCANDY42/emerge.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/LemonCANDY42/emerge#readme",
  "bugs": "https://github.com/LemonCANDY42/emerge/issues",
  "keywords": ["agent", "cli", "emerge", "llm", "runner"],
  "type": "module",
  "bin": {
    "emerge": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lwrf42/emerge-kernel": "workspace:^0.1.0",
    "@lwrf42/emerge-provider-mock": "workspace:^0.1.0",
    "@lwrf42/emerge-replay": "workspace:^0.1.0",
    "@lwrf42/emerge-telemetry-jsonl": "workspace:^0.1.0",
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
