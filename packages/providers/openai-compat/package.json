{
  "name": "@emerge/provider-openai-compat",
  "version": "0.1.0",
  "description": "OpenAI-compatible provider adapter for Ollama, vLLM, llama.cpp, and other OpenAI-compatible endpoints.",
  "license": "MIT",
  "author": "emerge contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LemonCANDY42/emerge.git",
    "directory": "packages/providers/openai-compat"
  },
  "homepage": "https://github.com/LemonCANDY42/emerge#readme",
  "bugs": "https://github.com/LemonCANDY42/emerge/issues",
  "keywords": ["agent", "llm", "ollama", "vllm", "openai-compatible", "emerge", "provider"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
