  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@emerge/provider-openai": "workspace:^0.1.0",
    "@emerge/kernel": "workspace:^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
