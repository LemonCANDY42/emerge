{
  "name": "@emerge/dashboard",
  "version": "0.1.0",
  "description": "Vite+React+WebSocket browser dashboard for monitoring emerge agent sessions in real time or replay.",
  "license": "MIT",
  "author": "emerge contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LemonCANDY42/emerge.git",
    "directory": "packages/dashboard"
  },
  "homepage": "https://github.com/LemonCANDY42/emerge#readme",
  "bugs": "https://github.com/LemonCANDY42/emerge/issues",
  "keywords": ["agent", "dashboard", "websocket", "react", "emerge", "monitor"],
  "type": "module",
  "bin": {
    "emerge-dashboard": "./dist/server/cli.js"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "build:client": "vite build --config vite.config.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@emerge/kernel": "workspace:^0.1.0",
    "@emerge/tui": "workspace:^0.1.0",
    "commander": "^12.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  }
}
