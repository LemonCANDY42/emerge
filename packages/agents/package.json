{
  "name": "@lwrf42/emerge-agents",
  "version": "0.1.0",
  "description": "Topology helpers and agent roles (supervisor, worker, pool, pipeline, adjudicator) for the emerge harness.",
  "license": "MIT",
  "author": "emerge contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LemonCANDY42/emerge.git",
    "directory": "packages/agents"
  },
  "homepage": "https://github.com/LemonCANDY42/emerge#readme",
  "bugs": "https://github.com/LemonCANDY42/emerge/issues",
  "keywords": ["agent", "llm", "multi-agent", "supervisor", "worker", "topology"],
  "type": "module",
